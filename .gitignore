# Виртуальное окружение и кэш Python
venv/
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# Секреты и локальная конфигурация
.env

# Архивы (не попадают в репозиторий)
IN/*.rar
IN/**/*.rar

# Каталог выходных данных целиком: SQLite, любые файлы — не коммитить
OUT/

# Логи
log/
*.log

# Системные файлы
.DS_Store

# Большие словари (пользователь кладёт сам); маленький пример оставляем в репозитории
wordlists/*.txt
!wordlists/rockyou_sample.txt
!wordlists/.gitkeep
